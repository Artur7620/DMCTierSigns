{
  "schemaVersion": 1,
  "id": "dmc_tiersigns",
  "version": "${version}",

  "name": "DMC TierSigns",
  "description": "Client-side mod for marking forbidden signs on dmc-minecraft.net.",
  "authors": ["sawiq_"],
  "contact": {
    "homepage": "https://modrinth.com/project/dmctiersigns",
    "sources": "https://github.com/imsawiq/DMCTierSigns",
    "issues": "https://github.com/imsawiq/DMCTierSigns/issues"
  },

  "license": "All-Rights-Reserved",
  "icon": "assets/dmc_tiersigns/icon.png",

  "environment": "*",
  "entrypoints": {
    "main": ["org.sawiq.dmc_tiersigns.Dmc_tiersigns"],
    "client": ["org.sawiq.dmc_tiersigns.client.DmcTierSignsClient"],
    "modmenu": ["org.sawiq.dmc_tiersigns.client.ModMenuIntegration"]
  },

  "mixins": [
    "dmc_tiersigns.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_compat_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
